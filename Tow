while true do
    local Vehicle = game.Workspace.PlayerVehicles["Caddy"]
    local TowTruck = game.Workspace.PlayerVehicles["Tow Truck"]

    local Events = game:GetService("ReplicatedStorage"):WaitForChild("_CS.Events")
    local LP = game.Players.LocalPlayer
    local CS = game:GetService("CollectionService")

    Events.LockCar:FireServer(Vehicle)
    repeat task.wait() until Vehicle.VehicleSeat.CarLocked.Value
    repeat task.wait(0.1) until not CS:HasTag(Vehicle, "LockDebounce") wait(1.15)
    Events.EnterVehicle:FireServer(Vehicle, "FrontLeft")
    repeat task.wait() until LP.Character.Humanoid.SeatPart
    LP.Character.Humanoid.SeatPart.Parent:SetPrimaryPartCFrame(CFrame.new(431, -4, -1777))
    wait(.5)
    LP.Character.Humanoid.Jump = true
    repeat task.wait() until not LP.Character.Humanoid.SeatPart wait(.1)

    LP.Character.HumanoidRootPart.CFrame = CFrame.new(395, -2, -1786)
    repeat task.wait() until (LP.Character.HumanoidRootPart.Position - Vector3.new(395, -2, -1786)).Magnitude < 5 wait(.5)
    
    Events.GetTowingTool:FireServer(TowTruck)
    repeat task.wait() until LP.Character:FindFirstChild("Tow Car")
    Events.TowCar:FireServer(TowTruck, "Tow", Vehicle)
    repeat task.wait() until Vehicle.VehicleSeat.Towed.Value and TowTruck.VehicleSeat.TowingVehicle.Value
    Events.TowCar:FireServer(TowTruck, "Release", Vehicle)
    repeat task.wait() until not Vehicle.VehicleSeat.Towed.Value and not TowTruck.VehicleSeat.TowingVehicle.Value
end





local TargetVehicle = "Caddy"

local Events = game:GetService("ReplicatedStorage"):WaitForChild("_CS.Events")
local LP = game.Players.LocalPlayer

local Vehicles = {}

while true do
    for i, v in pairs(game.Workspace.PlayerVehicles:GetChildren()) do
        if v.Name == TargetVehicle" then
            Vehicles[v] = {
                Locked = false
            }
            if v.VehicleSeat.CarLocked.Value then
                Vehicles[v].LockDebounce = true
                Events.LockCar:FireServer(v)
                task.spawn(function() task.wait(1.5) Vehicles[v].LockDebounce = false end)
            else
                
            end
        end
    end
    task.wait()
end
